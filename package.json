{
  "name": "pair-with-code",
  "displayName": "Pair With Code PRO",

  "publisher": "LJ-Tech",
  "version": "v1.0.0",
  "description": "Real-time collaborative coding with private rooms, synchronized typing, and multi-cursor tracking.",
  "repository": {
    "type": "git",
    "url": "https://github.com"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pairtool.copyRoomId",
        "title": "Pair Tool: Copy Room ID",
        "category": "Collaboration"
      },
      {
        "command": "pairtool.stopSharing",
        "title": "Pair Tool: Stop Sharing Session",
        "category": "Collaboration"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  },


  "dependencies": {
    "socket.io-client": "^4.8.3"
  }
}
